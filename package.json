{
  "name": "oae-site",
  "version": "1.0.0",
  "private": true,
  "description": "Site of Operator Asset Exchange",
  "scripts": {
    "clean:dist": "node -e \"require('fs').rmSync('public', { recursive: true, force: true })\"",
    "predev": "npm run clean:dist",
    "dev": "parcel serve src/index.html src/coming-soon.html src/privacy-policy.html src/cookie-policy.html src/terms-of-use.html --no-cache --dist-dir public --open",
    "prebuild": "npm run clean:dist",
    "build": "parcel build src/index.html src/coming-soon.html src/privacy-policy.html src/cookie-policy.html src/terms-of-use.html --dist-dir public --public-url . --no-source-maps",
    "build:release": "npm run build",
    "postbuild": "node scripts/sanitize-parcel-build.js",
    "visual:compare:regions": "node scripts/compare-home-regions.js",
    "typecheck": "tsc --noEmit",
    "image:site:build": "node ./scripts/docker/build-image.mjs site",
    "image:site:push": "node ./scripts/docker/push-image.mjs site",
    "images:build": "npm run build:release && npm run image:site:build",
    "images:push": "npm run image:site:push",
    "commit": "cz",
    "push": "git push --follow-tags origin $(git rev-parse --abbrev-ref HEAD)",
    "pull": "git pull --rebase origin $(git rev-parse --abbrev-ref HEAD)"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@parcel/transformer-sass": "2.16.3",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/gitlab": "^13.2.4",
    "@semantic-release/release-notes-generator": "^14.0.3",
    "@types/node": "^20.11.19",
    "@types/react": "^19.1.3",
    "@types/react-dom": "^19.1.3",
    "commitizen": "^4.3.1",
    "cz-git": "^1.11.1",
    "husky": "^9.1.7",
    "parcel": "^2.16.3",
    "sass": "^1.98.0",
    "semantic-release": "^24.2.3",
    "typescript": "^5.3.3"
  },
  "packageManager": "yarn@1.22.22",
  "config": {
    "commitizen": {
      "path": "cz-git"
    }
  }
}
